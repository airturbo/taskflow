# 任选其一配置你要用的 provider
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 可选：覆盖基础地址
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# CodeBuddy 宿主 adapter 不需要额外 API Key；
# 直接使用 --adapter codebuddy 即可生成 handoff 契约

# 通用执行参数
AGENT_TEAM_LLM_TIMEOUT_SECONDS=60
AGENT_TEAM_LLM_MAX_RETRIES=2
AGENT_TEAM_LLM_INITIAL_BACKOFF_SECONDS=1
AGENT_TEAM_LLM_MAX_BACKOFF_SECONDS=8
AGENT_TEAM_LLM_RETRY_STATUS_CODES=408,409,429,500,502,503,504

# 流式输出不需要额外开关；
# CLI 可直接使用 --stream 或 --stream-jsonl
