{
  "name": "todo-obsidian-plugin",
  "private": true,
  "version": "0.1.0",
  "description": "Isolated Obsidian plugin workstream for Todo Workspace",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "check": "tsc --noEmit --skipLibCheck",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "@taskflow/core": "file:../packages/taskflow-core",
    "obsidian": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
