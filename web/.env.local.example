# =====================================================
# FlowTask 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# .env.local 不会提交到 git（已加入 .gitignore）
# =====================================================

# Supabase 项目配置
# 从 Supabase Dashboard → Project Settings → API 获取
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 说明：
# - 未填写以上两个变量时，应用将以访客模式运行（仅本地 localStorage）
# - ANON KEY 是公开的，可以安全地暴露在前端代码中
# - 所有数据安全由 Supabase RLS（Row Level Security）策略保障
